<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary">

    <!-- Browse Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="@color/bg_primary">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Browse"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:letterSpacing="0.04" />

    </LinearLayout>

    <!-- Search bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="@drawable/bg_search_bar"
        android:gravity="center_vertical"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="12dp"
        android:paddingStart="14dp"
        android:paddingEnd="14dp">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_search"
            android:contentDescription="Search"
            android:layout_marginEnd="10dp" />

        <EditText
            android:id="@+id/et_search"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:hint="@string/search_hint"
            android:hintTextColor="@color/text_hint"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:background="@null"
            android:singleLine="true"
            android:imeOptions="actionSearch"
            android:inputType="text" />

    </LinearLayout>

    <!-- Genre filter chips row -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:scrollbars="none"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_all"
                style="@style/Widget.Aonime.FilterChip"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="@string/filter_all"
                android:checked="true"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_action"
                style="@style/Widget.Aonime.FilterChip"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="@string/filter_action"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_fantasy"
                style="@style/Widget.Aonime.FilterChip"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="@string/filter_fantasy"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_romance"
                style="@style/Widget.Aonime.FilterChip"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="@string/filter_romance"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_scifi"
                style="@style/Widget.Aonime.FilterChip"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="@string/filter_scifi"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_comedy"
                style="@style/Widget.Aonime.FilterChip"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="@string/filter_comedy" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- Anime Grid -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_browse_grid"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false"
        app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
        app:spanCount="2" />

</LinearLayout>
