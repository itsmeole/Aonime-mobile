<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary">

    <!-- Top App Bar -->
    <LinearLayout
        android:id="@+id/home_toolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="@color/bg_primary">

        <!-- App Logo small in toolbar -->
        <ImageView
            android:id="@+id/iv_toolbar_logo"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/ic_app_logo"
            android:scaleType="fitCenter"
            android:contentDescription="@string/content_desc_logo" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/app_name"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp"
            android:letterSpacing="0.04" />

    </LinearLayout>

    <!-- Scrollable content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ====== FEATURED BANNER SECTION ====== -->
            <FrameLayout
                android:id="@+id/featured_banner"
                android:layout_width="match_parent"
                android:layout_height="260dp">

                <!-- Poster background placeholder -->
                <ImageView
                    android:id="@+id/iv_featured_poster"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_featured_placeholder"
                    android:scaleType="centerCrop"
                    android:contentDescription="@string/content_desc_poster" />

                <!-- Gradient overlay at the bottom -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/gradient_banner" />

                <!-- Content overlay at bottom-left -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="16dp">

                    <!-- FEATURED badge -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/featured_label"
                        android:textColor="@color/accent_secondary"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.12"
                        android:layout_marginBottom="4dp" />

                    <!-- Featured title -->
                    <TextView
                        android:id="@+id/tv_featured_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="One-Punch Man Season 3"
                        android:textColor="@color/text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:maxLines="2"
                        android:ellipsize="end"
                        android:layout_marginBottom="6dp" />

                    <!-- Featured description -->
                    <TextView
                        android:id="@+id/tv_featured_desc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Saitama is a hero who became so powerful that he defeats every enemy with a single punch. Season 3 brings the Monster Association arc."
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:maxLines="2"
                        android:ellipsize="end"
                        android:layout_marginBottom="12dp" />

                    <!-- Buttons row -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btn_watch_now"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="@string/btn_watch_now"
                            android:textSize="12sp"
                            android:textColor="@color/text_primary"
                            android:background="@drawable/bg_watch_button"
                            android:paddingStart="20dp"
                            android:paddingEnd="20dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp" />

                    </LinearLayout>

                </LinearLayout>
            </FrameLayout>

            <!-- ====== TRENDING NOW SECTION ====== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="20dp">

                <!-- Section header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="18dp"
                        android:background="@color/accent_primary"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/section_trending"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- Horizontal RecyclerView for trending -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_trending"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:orientation="horizontal"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="false"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

            </LinearLayout>

            <!-- ====== LATEST EPISODES SECTION ====== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="20dp"
                android:paddingBottom="16dp">

                <!-- Section header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="18dp"
                        android:background="@color/accent_primary"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/section_latest"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- Vertical RecyclerView for latest - nested scrolling OFF so outer scroll handles it -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_latest"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="false"
                    app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                    app:spanCount="2" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
